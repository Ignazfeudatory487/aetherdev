{
  "name": "aetherdev",
  "version": "1.0.0",
  "description": "AetherDev — 100% free, open-source, self-healing AI developer agent. OpenClaw alternative with next-gen capabilities.",
  "author": "AetherDev Contributors",
  "license": "MIT",
  "private": true,
  "workspaces": [
    ".",
    "web-ui"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "dist/cli/index.js",
  "bin": {
    "aether": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:watch": "tsc -p tsconfig.json --watch",
    "dev": "ts-node-dev --respawn --transpile-only src/core/engine.ts",
    "cli": "ts-node cli/index.ts",
    "start": "node dist/cli/index.js",
    "web": "cd web-ui && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run web\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint src cli --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"cli/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "docker:build": "docker build -t aetherdev:latest .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup": "bash scripts/setup.sh",
    "db:migrate": "ts-node scripts/migrate.ts",
    "docs:build": "typedoc --out docs/api src/core/engine.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.12",
    "@inquirer/prompts": "^4.3.2",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "better-sqlite3": "^9.4.3",
    "ioredis": "^5.3.2",
    "axios": "^1.6.7",
    "openai": "^4.28.0",
    "pino": "^8.19.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "chokidar": "^3.6.0",
    "glob": "^10.3.10",
    "fast-glob": "^3.3.2",
    "simple-git": "^3.22.0",
    "tree-sitter": "^0.21.0",
    "tree-sitter-javascript": "^0.21.0",
    "tree-sitter-typescript": "^0.21.0",
    "tree-sitter-python": "^0.21.0",
    "vectra": "^0.7.0",
    "node-pty": "^1.0.0",
    "ws": "^8.16.0",
    "uuid": "^9.0.0",
    "ms": "^2.1.3",
    "semver": "^7.6.0",
    "yaml": "^2.4.1",
    "p-limit": "^5.0.0",
    "p-retry": "^6.2.0",
    "lru-cache": "^10.2.0",
    "sanitize-html": "^2.13.0",
    "vm2": "^3.9.19",
    "isolated-vm": "^4.7.2",
    "eventemitter3": "^5.0.1",
    "cron": "^3.1.6",
    "boxen": "^7.1.1",
    "figures": "^6.1.0",
    "strip-ansi": "^7.1.0",
    "table": "^6.8.1",
    "cli-progress": "^3.12.0",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "natural": "^6.12.0",
    "compromise": "^14.12.0",
    "node-microphone": "^0.1.2",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.14",
    "y-websocket": "^1.5.4",
    "recharts": "^2.12.2"
  },
  "devDependencies": {
    "typescript": "^5.4.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^20.11.25",
    "@types/better-sqlite3": "^7.6.8",
    "@types/ws": "^8.5.10",
    "@types/uuid": "^9.0.8",
    "@types/ms": "^0.7.34",
    "@types/semver": "^7.5.8",
    "@types/sanitize-html": "^2.11.0",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1",
    "playwright": "^1.42.1",
    "@playwright/test": "^1.42.1",
    "eslint": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "concurrently": "^8.2.2",
    "typedoc": "^0.25.12"
  }
}
