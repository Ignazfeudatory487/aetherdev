# ============================================================
# AetherDev Environment Configuration
# Copy to .env and fill in your values. NEVER commit .env!
# ============================================================

# --- Application ---
NODE_ENV=development
AETHER_PORT=3001
AETHER_HOST=0.0.0.0
AETHER_LOG_LEVEL=info
AETHER_LOG_FORMAT=pretty  # pretty | json
AETHER_SECRET_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# --- LLM Provider (All optional — local-first via Ollama) ---
# Ollama (LOCAL, FREE, RECOMMENDED)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:13b
OLLAMA_FALLBACK_MODEL=llama3:8b

# OpenAI-compatible API (optional fallback)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# LM Studio / LocalAI (optional)
LOCAL_LLM_BASE_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=

# --- Active LLM Provider: ollama | openai | anthropic | local ---
LLM_PROVIDER=ollama
LLM_MAX_TOKENS=8192
LLM_TEMPERATURE=0.2
LLM_REQUEST_TIMEOUT=120000

# --- Database ---
SQLITE_PATH=./data/aetherdev.db
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- Vector Store (local ChromaDB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=aetherdev_memory

# --- Security & Sandbox ---
SANDBOX_ENABLED=true
SANDBOX_TIMEOUT_MS=30000
SANDBOX_MAX_MEMORY_MB=512
SANDBOX_ALLOWED_COMMANDS=git,node,npm,python,pip,ls,cat,echo,mkdir,touch
SANDBOX_BLOCKED_COMMANDS=rm,curl,wget,ssh,nc,nmap,sudo,su

# --- Git Integration ---
GIT_USER_NAME=AetherDev Bot
GIT_USER_EMAIL=bot@aetherdev.local
GIT_AUTO_COMMIT=false
GIT_SIGN_COMMITS=false

# --- Web UI ---
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
VITE_APP_TITLE=AetherDev

# --- Collaboration (WebRTC/CRDT) ---
COLLAB_ENABLED=false
COLLAB_SIGNALING_URL=ws://localhost:3002
COLLAB_MAX_USERS=10

# --- Performance & Resources ---
MAX_CONCURRENT_AGENTS=4
AGENT_QUEUE_SIZE=100
MEMORY_CACHE_TTL=3600
CODE_INDEX_BATCH_SIZE=50
CPU_THROTTLE_PERCENT=80
MEMORY_LIMIT_MB=2048

# --- Telemetry (disabled by default — user must opt in) ---
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=

# --- Plugin System ---
PLUGINS_DIR=./plugins
PLUGINS_AUTO_RELOAD=true
PLUGINS_SANDBOX=true

# --- STT (Speech-to-Text, optional) ---
STT_ENABLED=false
STT_PROVIDER=whisper  # whisper | vosk
WHISPER_MODEL=base.en

# --- CI/CD ---
CI=false
CI_FAIL_ON_SECURITY_ISSUES=true
CI_FAIL_ON_COMPLEXITY_THRESHOLD=20
